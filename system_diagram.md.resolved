## Rotas da API

```mermaid
graph LR
    subgraph Auth
        POST_login["POST /api/auth/login"]
    end

    subgraph Products
        GET_products["GET /api/products"]
        POST_product["POST /api/products"]
        PUT_product["PUT /api/products/:id"]
        DEL_product["DELETE /api/products/:id"]
        PUT_stock["PUT /api/products/:id/stock"]
        GET_barcode["GET /api/products/barcode/:barcode"]
    end

    subgraph Assets_Routes["Assets"]
        GET_assets["GET /api/assets"]
        POST_asset["POST /api/assets"]
        PUT_asset["PUT /api/assets/:id"]
        DEL_asset["DELETE /api/assets/:id"]
        PUT_asset_status["PUT /api/assets/:id/status"]
    end

    subgraph Users_Routes["Users"]
        GET_users["GET /api/users"]
        POST_user["POST /api/users"]
        PUT_user["PUT /api/users/:id"]
        PUT_user_status["PUT /api/users/:id/status"]
    end

    subgraph Departments_Routes["Departments"]
        GET_depts["GET /api/departments"]
        POST_dept["POST /api/departments"]
        PUT_dept["PUT /api/departments/:id"]
        PUT_dept_status["PUT /api/departments/:id/status"]
    end

    subgraph Dashboard_Routes["Dashboard"]
        GET_stats["GET /api/dashboard/stats"]
        GET_movements["GET /api/dashboard/movements"]
    end

    subgraph Logs_Routes["Logs"]
        GET_logs["GET /api/logs"]
    end

    style Auth fill:#fecaca,stroke:#ef4444
    style Products fill:#dbeafe,stroke:#3b82f6
    style Assets_Routes fill:#dcfce7,stroke:#22c55e
    style Users_Routes fill:#f3e8ff,stroke:#a855f7
    style Departments_Routes fill:#fef3c7,stroke:#f59e0b
    style Dashboard_Routes fill:#e0e7ff,stroke:#6366f1
    style Logs_Routes fill:#f1f5f9,stroke:#64748b
```

